---
import SearchBar from '../components/SearchBar.astro';
import PopularSidebar from '../components/PopularSidebar.astro';
import "../styles/site.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>About | N Benchmarks</title>
    <meta name="description" content="About N Benchmarks — real-world GPU and CPU performance tests on an RTX 4060 + Ryzen 5 5600G build." />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  </head>
  <body>
    <div class="wrap">

      <header>
        <a class="logo" href="/">N Benchmarks</a>
        <SearchBar />
        <nav>
          <a href="/">Home</a>
          <a href="/most-popular">Popular Benchmarks</a>
          <a href="/about">About</a>
        </nav>
      </header>

      <div class="page-body">
        <main>
          <div class="about-card">
            <div class="eyebrow">About</div>
            <h1>What is N Benchmarks?</h1>
            <p>
              N Benchmarks is a site dedicated to real-world GPU and CPU performance testing.
              Every benchmark here is recorded and analysed on the same rig so results are
              directly comparable across games and settings.
            </p>
            <h2>The Test Rig</h2>
            <ul class="about-specs">
              <li><strong>GPU:</strong> NVIDIA GeForce RTX 4060 8 GB GDDR6</li>
              <li><strong>CPU:</strong> AMD Ryzen 5 5600G (6 cores / 12 threads)</li>
              <li><strong>RAM:</strong> 16 GB DDR4 3400 MHz</li>
              <li><strong>Motherboard:</strong> ASUS B450M Gaming</li>
              <li><strong>Storage:</strong> Kingston NV1 500 GB NVMe SSD</li>
            </ul>
            <h2>Who makes this?</h2>
            <p>
              Hi, I'm Nicolas. I run the
              <a href="https://www.youtube.com/@NBenchmarks" target="_blank" rel="noopener noreferrer">N Benchmarks YouTube channel</a>
              where I post video benchmarks for the same games you'll find here.
              This site exists as a complement to the channel — searchable, readable,
              and easy to reference when you're deciding whether a game will run well
              on your hardware.
            </p>
            <h2>Methodology</h2>
            <p>
              All tests are run at the graphics preset stated in each post with no manual
              driver tweaks or overclocking unless explicitly mentioned. I capture FPS data
              using CapFrameX and record footage with OBS.
            </p>
            <a class="cta" href="/" style="display:inline-block; margin-top:24px; color: #fff;">
              &larr; Back to benchmarks
            </a>
          </div>
        </main>

        <aside class="page-sidebar">
          <PopularSidebar />
        </aside>
      </div>

      <footer>
        &copy; {new Date().getFullYear()} N Benchmarks &mdash; All rights reserved
      </footer>

    </div>
  </body>
</html>

<style>
  .about-card {
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 40px 48px;
    width: 100%;
    margin: 0 auto;
  }
  .about-card h1 {
    font-size: 32px;
    margin: 10px 0 20px;
  }
  .about-card h2 {
    font-size: 20px;
    margin: 32px 0 12px;
  }
  .about-card p {
    line-height: 1.7;
    color: #222;
    margin: 0 0 16px;
  }
  .about-card a {
    color: var(--accent);
  }
  .about-specs {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0 0 16px;
  }
  .about-specs li {
    font-size: 15px;
    color: #333;
  }
  @media (max-width: 600px) {
    .about-card { padding: 24px 20px; }
  }
</style>
