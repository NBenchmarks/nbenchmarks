---
import "../styles/site.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>404 — Page Not Found | N Benchmarks</title>
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  </head>
  <body>
    <div class="wrap" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:80vh; text-align:center;">
      <div class="eyebrow" style="font-size:72px; margin-bottom:0;">404</div>
      <h1 style="font-size:28px; margin:8px 0 16px;">Page not found</h1>
      <p style="color:var(--muted); max-width:400px; margin-bottom:28px;">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a class="cta" href="/">&larr; Back to all benchmarks</a>
    </div>
  </body>
</html>
